<%- include("partials/header.ejs") %>
<main>
  <section>
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="max-w-screen-md mb-8 lg:mb-16">
        <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900 dark:text-white">Notifications</h2>
        <p class="text-gray-500 sm:text-xl dark:text-gray-400">Your latest notifications.</p>
      </div>
      <div class="space-y-4">
        <% if(notifications.length > 0) { %>
        <% notifications.forEach(notification => { %>
        <div class="border border-gray-200 rounded-lg p-5 dark:border-gray-700">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xl font-bold dark:text-white"><%= notification.title %></h3>
            <% if(!notification.seen) { %>
            <span class="text-xs font-medium px-2.5 py-0.5 rounded bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">New</span>
            <% } %>
          </div>
          <p class="text-gray-500 dark:text-gray-400"><%= notification.message %></p>
        </div>
        <% }) %>
        <% } else { %>
        <p class="text-center text-gray-500 dark:text-gray-400">No notifications yet.</p>
        <% } %>
      </div>
      <div class="mt-8">
        <a href="/" class="text-primary-700 hover:underline font-medium dark:text-primary-500">Back to Home</a>
      </div>
    </div>
  </section>
</main>
<%- include("partials/footer.ejs") %>
